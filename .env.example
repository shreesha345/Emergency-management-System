# RudraOne Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================================================
# 🦙 OLLAMA CONFIGURATION (Local AI Model)
# ============================================================================

# Enable or disable Ollama integration
# true: Use local Ollama for all AI tasks (RECOMMENDED)
# false: Disable AI features (fallback mode)
OLLAMA_ENABLED=true

# Ollama server URL
# Default: http://localhost:11434
# Remote: http://your-server-ip:11434
OLLAMA_BASE_URL=http://localhost:11434

# Model to use for all AI tasks
# Options:
#   - gemma4:31b - Primary model for best quality (hardware dependent)
# Default: gemma4:31b
OLLAMA_MODEL=gemma4:31b

# ============================================================================
# 🔐 TWILIO CONFIGURATION (Phone & SMS)
# ============================================================================

TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# Also try these environment variable names (some systems use these)
VITE_TWILIO_ACCOUNT_SID=your_account_sid_here
VITE_TWILIO_AUTH_TOKEN=your_auth_token_here
VITE_TWILIO_PHONE_NUMBER=your_twilio_phone_number

# ============================================================================
# 🗄️ DATABASE CONFIGURATION
# ============================================================================

# PostgreSQL Connection String
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://rudraone_user:secure_password@localhost:5432/rudraone_db

# Database connection pool settings
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# ============================================================================
# 🎤 SPEECH SERVICES CONFIGURATION
# ============================================================================

# Deepgram API Key (Speech-to-Text)
# For audio transcription during calls
DEEPGRAM_API_KEY=your_deepgram_api_key

# ElevenLabs API Key (Text-to-Speech)
# For generating voice responses
# ELEVENLABS_API_KEY=your_elevenlabs_api_key

# Sarvam AI API Key (Alternative TTS)
# Particularly good for Indian languages (Hindi, Tamil, etc.)
SARVAM_API_KEY=your_sarvam_api_key

# ============================================================================
# 🌍 LOCATION & MAPPING SERVICES
# ============================================================================

# Mapbox API Token (for maps, geocoding, and directions)
# Sign up at: https://account.mapbox.com/
# Used in frontend for dispatch map visualization and routing
VITE_MAPBOX_TOKEN=your_mapbox_token_here

# ============================================================================
# 🚀 SERVER CONFIGURATION
# ============================================================================

# Server port
PORT=8000

# Server environment (development, staging, production)
ENVIRONMENT=development

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000

# Ngrok URL (for development, allows external access)
# Leave empty for local development
NGROK_URL=

# ============================================================================
# 📊 ANALYTICS & LOGGING
# ============================================================================

# Logging level
LOG_LEVEL=INFO

# Enable debug mode
DEBUG=false

# ============================================================================
# 📱 FRONTEND CONFIGURATION
# ============================================================================

# Frontend environment variables (if using Vite React frontend)
VITE_API_URL=http://localhost:8000
VITE_ENVIRONMENT=development

# Frontend Gemini (deprecated, kept for compatibility)
VITE_GOOGLE_API_KEY=your_google_api_key

# ============================================================================
# 🎓 TRAINING SYSTEM CONFIGURATION (Deprecated - now uses Ollama)
# ============================================================================

# Previous training system configuration (no longer needed)
# These are here for reference/backward compatibility only
# TRAINING_AI_PROVIDER=google
# TRAINING_GOOGLE_MODEL=gemini-2.5-flash
# TRAINING_OPENAI_MODEL=gpt-4o

# ============================================================================
# ⚙️ ADVANCED OLLAMA CONFIGURATION (Optional)
# ============================================================================

# Number of GPU layers to use
# 0: CPU only
# Higher values: More GPU memory usage but faster
# OLLAMA_NUM_GPU=1

# Context window size (tokens)
# Higher values: More memory, better context understanding
# OLLAMA_NUM_CTX=4096

# Debug mode for Ollama
# OLLAMA_DEBUG=0

# ============================================================================
# 🔒 SECURITY & DEPLOYMENT
# ============================================================================

# JWT Secret for API authentication (change this in production)
JWT_SECRET=your-super-secret-key-change-in-production

# Session timeout (in minutes)
SESSION_TIMEOUT=30

# Enable HTTPS (production only)
USE_HTTPS=false

# ============================================================================
# 📝 NOTES
# ============================================================================
# 
# 1. OLLAMA_ENABLED=true is the recommended configuration
#    - All AI tasks run locally
#    - No cloud API calls for LLM generation
#    - Full privacy and control
#    - No API billing
#
# 2. To use Ollama:
#    - Install from https://ollama.ai
#    - Run: ollama pull gemma4:31b
#    - Start: ollama serve
#
# 3. Required services:
#    - PostgreSQL database (for call logging)
#    - Ollama server (for AI tasks)
#    - Twilio account (for phone/SMS)
#
# 4. Optional but recommended:
#    - Deepgram or ElevenLabs for audio processing
#    - Sarvam for Indian language support
#
# 5. For development:
#    - Use localhost URLs
#    - Set ENVIRONMENT=development
#    - Enable DEBUG=true (optional)
#
# 6. For production:
#    - Use strong secrets
#    - Set ENVIRONMENT=production
#    - Use production database
#    - Enable HTTPS
#    - Use environment-specific URLs
#
# ============================================================================
